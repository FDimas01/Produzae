  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\"A educa\xE7\xE3o tem ra\xEDzes amargas, mas os seus frutos s\xE3o doces.\"\n\u2014
    Arist\xF3teles, fil\xF3sofo grego.\n\n\"Educai as crian\xE7as e n\xE3o ser\xE1
    preciso punir os homens.\"\n\u2014 Pit\xE1goras, fil\xF3sofo e matem\xE1tico
    grego.\n\n\"A educa\xE7\xE3o visa melhorar a natureza do homem o que nem sempre
    \xE9 aceite pelo interessado.\"\n\u2014 Carlos Drummond de Andrade, poeta, cronista
    e contista da segunda gera\xE7\xE3o do modernismo brasileiro.\n\n\"A educa\xE7\xE3o
    \xE9 a arma mais poderosa que voc\xEA pode usar para mudar o mundo.\"\n\u2014
    Nelson Mandela, pai da moderna na\xE7\xE3o sul-africana, l\xEDder na luta contra
    o regime do apartheid.\n\n\"O ser humano \xE9 aquilo que a educa\xE7\xE3o faz
    dele.\"\n\u2014 Immanuel Kant, fil\xF3sofo alem\xE3o.\n\n\"Se a educa\xE7\xE3o
    sozinha n\xE3o transforma a sociedade, sem ela tampouco a sociedade muda.\"\n\u2014
    Paulo Freire, educador, pedagogo e fil\xF3sofo brasileiro.\n\n\"Feliz aquele
    que transfere o que sabe e aprende o que ensina.\"\n\u2014 Cora Coralina, escritora,
    poetisa e contista brasileira.\n\n\"Se queres prever o futuro, estuda o passado.\"\n\u2014
    Conf\xFAcio, fil\xF3sofo e pensador chin\xEAs.\n\n\"A boa educa\xE7\xE3o \xE9
    moeda de ouro. Em toda a parte tem valor.\"\n\u2014 Padre Ant\xF4nio Vieira,
    religioso da Companhia de Jesus."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
