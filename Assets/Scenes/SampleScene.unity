--- !u!114 &1367501996
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1367501994}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\"Sa\xFAde \xE9 o estado de completo bem-estar f\xEDsico, mental e social
    e n\xE3o somente a aus\xEAncia de doen\xE7a.\"\n\u2014 Defini\xE7\xE3o da Organiza\xE7\xE3o
    Mundial de Sa\xFAde.\n\n\"A sa\xFAde \xE9 direito de todos e dever do estado,
    garantido mediante pol\xEDticas sociais e econ\xF4micas que visem a redu\xE7\xE3o
    do risco de doen\xE7as e de outros agravos e ao acesso universal e igualit\xE1rio
    \xE0s a\xE7\xF5es e servi\xE7os para a sua promo\xE7\xE3o, prote\xE7\xE3o e recupera\xE7\xE3o.\"\n\u2014
    Art. 196 da Constitui\xE7\xE3o Federal do Brasil.\n\n\"O homem saud\xE1vel \xE9
    aquele que possui um estado mental e f\xEDsico em perfeito equil\xEDbrio.\"\n\u2014
    Hip\xF3crates, m\xE9dico e fil\xF3sofo da Gr\xE9cia Antiga, considerado o pai
    da medicina.\n\n\"O Estado preocupa-se com a sa\xFAde do indiv\xEDduo em fun\xE7\xE3o
    de sua utiliza\xE7\xE3o como instrumento de trabalho e n\xE3o em fun\xE7\xE3o
    de suas esperan\xE7as, de seus anseios, de seus temores ou de seus sofrimentos.\"\n\u2014
    Jayme Landmann, m\xE9dico e professor brasileiro.\n\n\"Temos de ser contra a
    distor\xE7\xE3o a que estamos assistindo, em nosso pa\xEDs, da coexist\xEAncia
    do mais alto n\xEDvel de assist\xEAncia m\xE9dica e do mais baixo n\xEDvel de
    assist\xEAncia \xE0 sa\xFAde, na mesma cidade e no mesmo local.\"\n\u2014 Adib
    Domingos Jatene, m\xE9dico, professor universit\xE1rio, inventor e cientista
    brasileiro.\n\n\"\xC9 imposs\xEDvel dar sa\xFAde a quem veste trapos e trabalha
    com sal\xE1rios que n\xE3o permitem condi\xE7\xF5es m\xEDnimas de subsist\xEAncia.
    \xC9 imposs\xEDvel dar sa\xFAde a um povo se n\xE3o o libertarmos de sua depend\xEAncia
    econ\xF4mica para que ele mesmo tome suas decis\xF5es.\"\n\u2014 Salvador Allende,
    m\xE9dico e ex-presidente do Chile."
  m_isRightToLeft: 0
