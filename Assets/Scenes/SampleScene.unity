  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Divertida Mente (2015): Aborda temas como depress\xE3o, emo\xE7\xF5es
    e doen\xE7as mentais\n\nO m\xEDnimo para viver (2017): Explora temas como transtornos
    alimentares e padr\xF5es est\xE9ticos\n\nGrey's Anatomy: Aborda temas como dificuldades
    no sistema de sa\xFAde, cren\xE7a e ci\xEAncia\n\nO Dilema das Redes (2020):
    Relata os problemas que as redes sociais podem causar \xE0 sa\xFAde mental\n\nCoringa
    (2019): Explora temas como aliena\xE7\xE3o, isolamento social e doen\xE7a mental\n\nPreciosa
    \u2013 Uma Hist\xF3ria de Esperan\xE7a (2009): Conta a hist\xF3ria de uma adolescente
    que enfrenta abuso psicol\xF3gico e sexual, discrimina\xE7\xE3o e gordofobia\n\nUm
    golpe do destino: Explora a rela\xE7\xE3o entre m\xE9dico e paciente e o atendimento
    humanizado\n\nMeu p\xE9 esquerdo: Mostra a hist\xF3ria de um homem que nasce
    com paralisia cerebral e se torna escritor e pintor"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
