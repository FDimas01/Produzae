--- !u!114 &1147467900
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1147467898}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#FF8C42>Outrossim, </color>a <color=#F06292>perman\xEAncia hist\xF3rica</color>
    \xE9 fator importante como constituinte desse imbr\xF3glio. </color><color=#F06292>Nesse
    sentido, </color><color=#4DB68C>consoante ao pensamento do antrop\xF3logo Claude
    L\xE9vi-Strauss, s\xF3 \xE9 poss\xEDvel compreender adequadamente as a\xE7\xF5es
    coletivas por meio do entendimento dos eventos hist\xF3ricos. </color><color=#FF8C42>Desse
    modo, </color><color=#6A4BBF>a quest\xE3o da invisibilidade do trabalho de cuidado
    feito por mulheres majoritariamente pobres e v\xEDtimas de discrimina\xE7\xE3o
    de g\xEAnero, mesmo que fortemente presente no s\xE9culo XXI, apresenta ra\xEDzes
    indissoci\xE1veis \xE0 hist\xF3ria brasileira - que foi marcada pelo machismo
    e pelo patriarcado -, uma vez que as atividades dom\xE9sticas n\xE3o pagas ainda
    s\xE3o delegadas \xE0s pessoas do sexo feminino de forma quase que exclusiva.
    </color><color=#FF8C42>Logo, </color><color=#FF0000>as pr\xE1ticas coloniais
    colaboram com a perman\xEAncia desse pensamento.</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
