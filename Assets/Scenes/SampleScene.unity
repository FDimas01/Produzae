  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Lei Maria da Penha (Lei n\xBA 11.340, 2006)\n\nLei do Feminic\xEDdio (Lei
    n\xBA 13.104, 2015)\n\nLei do Minuto Seguinte (Lei n\xBA 12.845/2013)\n\nLei
    14.899/24, que determina a cria\xE7\xE3o de um plano de metas para o enfrentamento
    da viol\xEAncia contra as mulheres.\n\nPL 2325/2021, que altera o C\xF3digo Penal
    e o C\xF3digo de Processo Penal para excluir os crimes de viol\xEAncia."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
