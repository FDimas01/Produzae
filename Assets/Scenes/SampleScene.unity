      m_Calls: []
  m_text: "Lei n\xBA 12.711/2012 (Lei de Cotas): Garante reserva de vagas para estudantes
    de escolas p\xFAblicas, pretos, pardos, ind\xEDgenas e pessoas com defici\xEAncia
    em universidades e institutos federais.\n\nEstatuto da Igualdade Racial (Lei
    n\xBA 12.288/2010): Assegura a igualdade de oportunidades e combate a discrimina\xE7\xE3o
    racial."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
