  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#FF8C42>Faz-se necess\xE1rio, portanto, </color><color=#000000>que
    meios sejam criados para intervir nesse \xF3bice. Logo, o </color><color=#4DB68C>Governo
    Federal </color><color=#6A4BBF>- \xF3rg\xE3o respons\xE1vel pela administra\xE7\xE3o
    federal em todo territ\xF3rio nacional - </color><color=#F06292>deve estabelecer</color>
    pol\xEDticas p\xFAblicas que garantam a remunera\xE7\xE3o e a valoriza\xE7\xE3o
    do trabalho de cuidado, <color=#FF0000>por meio </color><color=#000000>da utiliza\xE7\xE3o
    de verbas governamentais para o pagamento de sal\xE1rios. Tal a\xE7\xE3o deve
    ser realizada </color><color=#00FFFF>com a finalidade de</color> mitigar a invisibilidade
    dos afazeres dom\xE9sticos realizados pela mulher na sociedade brasileira e,
    consequentemente, combater as ra\xEDzes hist\xF3ricas presentes nessa quest\xE3o.<color=#FF8C42>Dessarte,
    </color><color=#000000>o Brasil poder\xE1 se tornar um \"Pa\xEDs do Futuro\",
    como defendido por Stefan Zweig.</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
