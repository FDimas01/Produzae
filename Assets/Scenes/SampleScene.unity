--- !u!114 &793873481
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 793873479}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#FF8C42>Sob este vi\xE9s,</color> \xE9 preciso atentar para a <color=#F06292>omiss\xE3o
    estatal</color> <color=#000000>presente nessa problem\xE1tica. </color><color=#FF8C42>Nessa
    perspectiva, </color><color=#4DB68C>o pensador Thomas Hobbes afirma que o Estado
    \xE9 respons\xE1vel por garantir o bem-estar da popula\xE7\xE3o. </color><color=#FF8C42>Entretanto,
    </color><color=#6A4BBF>isso n\xE3o ocorre no Brasil, pois a falta de atua\xE7\xE3o
    das autoridades corrobora a perman\xEAncia do trabalho de cuidado n\xE3o remunerado
    e mal pago realizado, principalmente, por mulheres - que inclui cuidar de crian\xE7as
    e idosos, bem como os afazeres dom\xE9sticos -, visto que o Governo n\xE3o tem
    cumprido seu papel no sentido de assegurar os direitos b\xE1sicos a esse grupo
    social, como o direito a um sal\xE1rio digno. </color><color=#FF8C42>Assim, </color><color=#FF0000>as
    fun\xE7\xF5es sociais e estatais s\xE3o descumpridas, agravando o problema.</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
