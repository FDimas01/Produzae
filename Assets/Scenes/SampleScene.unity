  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Esse proposta de interven\xE7\xE3o est\xE1 completa, pois nela v\xEA-se
    os </color><color=#FF8C42>conectivos necess\xE1rios em laranja</color><color=#000000>,
    quem vai fazer - </color><color=#4DB68C>agente - em verde</color><color=#000000>,
    o </color><color=#6A4BBF>detalhamento desse agente em azul</color><color=#000000>,
    a </color><color=#F06292>a\xE7\xE3o a ser desenvolvida em rosa</color><color=#000000>,
    o como isso ser\xE1 feito em </color><color=#FF0000>vermelho (meio/modo)</color><color=#000000>
    e a sua finalidade em </color><color=#00FFFF>azul beb\xEA</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
