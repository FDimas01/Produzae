  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#6A4BBF>Na obra intitulada 'Brasil, Pa\xEDs do Futuro', Stefan
    Zweig, autor austr\xEDaco, em sua visita ao Brasil, defendeu a ideia de que o
    pa\xEDs estava destinado a ser um dos mais importantes pa\xEDses do mundo no
    futuro</color>. <color=#FF8C42>No entanto</color>, 80 anos depois, as previs\xF5es
    do autor ainda n\xE3o se concretizaram e os desafios <color=#4DB68C>para enfrentar
    a invisibilidade do trabalho de cuidado - realizado por mulheres</color> <color=#FF8C42>-</color>
    s\xE3o entraves para isso. Observa-se, assim, que isso ocorre porque <color=#F06292>a
    neglig\xEAncia governamental e a perman\xEAncia hist\xF3rica</color> impedem
    a resolu\xE7\xE3o da quest\xE3o\""
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
