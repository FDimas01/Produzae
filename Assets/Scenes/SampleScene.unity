  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Elaborar uma proposta de interven\xE7\xE3o na prova de reda\xE7\xE3o do
    Enem representa uma ocasi\xE3o para que voc\xEA demonstre seu preparo para o
    exerc\xEDcio da cidadania, para atuar na realidade em conson\xE2ncia com os direitos
    humanos. Voc\xEA deve usar seus conhecimentos desenvolvidos ao longo de sua forma\xE7\xE3o
    para a produ\xE7\xE3o de um texto no qual, al\xE9m de se posicionar de maneira
    cr\xEDtica e argumentar a favor de um ponto de vista, voc\xEA possa indicar uma
    iniciativa que interfira no problema discutido em sua reda\xE7\xE3o. Para isso,
    a proposta de interven\xE7\xE3o precisa estar relacionada ao tema e integrada
    ao seu projeto de texto. Ao redigir seu texto, busque apresentar uma proposta
    concreta, espec\xEDfica ao tema e consistente com o desenvolvimento de suas ideias.\nAo
    elaborar sua proposta, procure responder \xE0s seguintes perguntas:\n1. O que
    \xE9 poss\xEDvel apresentar como proposta de interven\xE7\xE3o para o problema?\n2.
    Quem deve execut\xE1-la?\n3. Como viabilizar essa proposta?\n4. Qual efeito ela
    pode alcan\xE7ar?\n5. Que outra informa\xE7\xE3o pode ser acrescentada para detalhar
    a proposta?"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
