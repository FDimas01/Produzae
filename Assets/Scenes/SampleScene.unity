  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\"Viol\xEAncia n\xE3o \xE9 um sinal de for\xE7a, a viol\xEAncia \xE9 um
    sinal de desespero e fraqueza.\"\n\u2014 Dalai Lama, monge budista. Recebeu o
    Pr\xEAmio Nobel da Paz.\n\n\"Poder e viol\xEAncia s\xE3o opostos; onde um domina
    absolutamente, o outro est\xE1 ausente\"\n\u2014 Hannah Arendt, fil\xF3sofa pol\xEDtica.
    Reprodu\xE7\xE3o Wikipedia.\n\n\"A for\xE7a gerada pela n\xE3o viol\xEAncia \xE9
    infinitamente maior do que a for\xE7a de todas as armas inventadas pela engenhosidade
    do homem.\"\n\u2014 Mahatma Gandhi, l\xEDder pacifista indiano.\n\n\"Poder \xE9
    fazer com que o outro fa\xE7a o que voc\xEA quer e sem o uso da viol\xEAncia
    real.\"\n\u2014 Max Weber, soci\xF3logo.\n\n\"Uma crian\xE7a, um professor, um
    livro e uma caneta podem mudar o mundo.\"\n\u2014 Malala Yousafzai, ativista
    paquistanesa. A mais jovem a receber o Nobel da Paz.\n\n\"A paz mundial vir\xE1
    quando a compreens\xE3o substituir o \xF3dio nas mentes das pessoas.\"\n\u2014
    Yoko Ono, ativista e m\xFAsica japonesa."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
