  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Wall Street: Poder e Cobi\xE7a\n\nO Homem que Mudou o Jogo\n\nReal: O
    Plano por Tr\xE1s da Hist\xF3ria\n\nA Grande Aposta\n\nFreakonomics: o Lado Oculto
    e Inesperado de Tudo que nos Afeta\n\nApostando no Zero\n\nO Lobo de Wall Street\n\nA
    Ascens\xE3o do Dinheiro\n\nA Fraude\n\nTrabalho Interno\n\nUm Novo Capitalismo\n\nUma
    Mente Brilhante\n\nCapitalismo: Uma Hist\xF3ria de Amor"
