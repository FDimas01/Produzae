  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Marco Civil da Internet (Lei n\xBA 12.965/2014): estabelece princ\xEDpios,
    garantias, direitos e deveres para o uso da internet no Brasil, abordando temas
    como privacidade, liberdade de express\xE3o e neutralidade da rede.\n\nLei Geral
    de Prote\xE7\xE3o de Dados (LGPD \u2013 Lei n\xBA 13.709/2018): regula o tratamento
    de dados pessoais no Brasil, visando proteger a privacidade dos cidad\xE3os e
    estabelecer diretrizes para o uso de dados pelas empresas.\n\n\"Admir\xE1vel
    Chip Novo\" \u2013 Pitty: a m\xFAsica critica a padroniza\xE7\xE3o e o controle
    exercidos pela tecnologia sobre os indiv\xEDduos, abordando a aliena\xE7\xE3o
    e a perda de individualidade na era digital.\n\n\"Pela Internet\" \u2013 Gilberto
    Gil: Esta m\xFAsica aborda a revolu\xE7\xE3o causada pela internet na comunica\xE7\xE3o
    e na cultura, discutindo as mudan\xE7as sociais e culturais trazidas pela era
    digital.\n\n\"1984\" \u2013 George Orwell: um cl\xE1ssico que explora um governo
    totalit\xE1rio, vigil\xE2ncia extrema e manipula\xE7\xE3o da verdade. Tem\xE1ticas
    como controle social, fake news, liberdade de express\xE3o e a manipula\xE7\xE3o
    midi\xE1tica s\xE3o abordadas."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
