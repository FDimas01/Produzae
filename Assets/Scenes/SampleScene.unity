  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\"Economia, frequentemente, n\xE3o tem rela\xE7\xE3o com o total de dinheiro
    gasto, mas com a sabedoria empregada ao gast\xE1-lo.\"\n\u2014 Henry Ford\n\n\"Estudo
    economia diariamente, para nunca ser enganada por nenhum economista.\"\n\u2014
    Joan Robinson\n\n\"O que caracteriza a economia pol\xEDtica burguesa \xE9 que
    ela v\xEA na ordem capitalista n\xE3o uma fase transit\xF3ria do progresso hist\xF3rico,
    mas a forma absoluta e definitiva da produ\xE7\xE3o social.\"\n\u2014 Karl Marx\n\n\"A
    economia do tempo \xE9 menos vulgar e mais importante que a do dinheiro\"\n\u2014
    Marqu\xEAs de Maric\xE1\n\n\"A hist\xF3ria, a economia, a pol\xEDtica, a cultura,
    a percep\xE7\xE3o, a mem\xF3ria, a identidade e a experi\xEAncia est\xE3o todas
    elas hoje mediadas pelas tecnologias digitais.\"\n\u2014 Lucia Santaella\n\n\"A
    tecnologia moderna \xE9 capaz de realizar a produ\xE7\xE3o sem emprego.\"\n\u2014
    Herbert de Souza (Betinho)"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
