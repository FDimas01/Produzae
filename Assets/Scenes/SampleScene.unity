--- !u!114 &1150752340
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1150752338}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\"A tecnologia move o mundo.\"\n\u2014 Steve Jobs, inventor e fundador
    da Apple.\n\n\"O esp\xEDrito humano precisa prevalecer sobre a tecnologia.\"\n\u2014
    Albert Einstein, cientista alem\xE3o.\n\n\"Se tornou aparentemente \xF3bvio que
    nossa tecnologia excedeu nossa humanidade.\"\n\u2014 Albert Einstein, cientista
    alem\xE3o.\n\n\"O problema n\xE3o \xE9 se as m\xE1quinas pensam, mas se os homens
    fazem.\"\n\u2014 B.F. Skinner, psic\xF3logo e cientista do comportamento humano.\n\n\"Um
    ser humano deve transformar informa\xE7\xE3o em intelig\xEAncia ou conhecimento.
    Tendemos a esquecer que nenhum computador jamais far\xE1 uma nova pergunta.\"\n\u2014
    Grace Hopper, cientista da computa\xE7\xE3o pioneira em programa\xE7\xE3o.\n\n\"Sempre
    teremos Ci\xEAncia, Tecnologia, Engenharia e Matem\xE1tica conosco. Algumas coisas
    sair\xE3o dos olhos do p\xFAblico e ir\xE3o embora, mas sempre haver\xE1 ci\xEAncia,
    engenharia e tecnologia. E sempre, sempre haver\xE1 matem\xE1tica.\"\n\u2014
    Katherine Johnson, matem\xE1tica, f\xEDsica e cientista espacial da NASA.\n\n\"A
    tecnologia \xE9 uma palavra que descreve alguma coisa que ainda n\xE3o funciona.\"\n\u2014
    Douglas Adams, escritor ingl\xEAs, autor d'O Guia do Mochileiro das Gal\xE1xias.\n\n\"N\xF3s
    estamos presos \xE0 tecnologia quando o que n\xF3s mais queremos \xE9 algo que
    apenas funcione.\"\n\u2014 Douglas Adams, escritor ingl\xEAs."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
